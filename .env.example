# CogniCap Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- App Security ---
JWT_SECRET=            # Random 64+ char secret for signing JWTs (required)
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"

# --- Zerodha Kite Broker ---
KITE_API_KEY=
KITE_API_SECRET=

# --- AI API Keys ---
ANTHROPIC_API_KEY=     # Required for sell pipeline + conviction scoring
GEMINI_API_KEY=        # Required for buy pipeline + chat agents
OPENAI_API_KEY=        # Optional fallback when Gemini hits rate limits

# --- Flask ---
FLASK_PORT=5000
FLASK_DEBUG=false

# --- CORS ---
# Comma-separated list of allowed origins (default: http://localhost:4200)
CORS_ORIGINS=http://localhost:4200
